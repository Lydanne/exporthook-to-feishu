PORT=8001

# Bull Board
BULL_BOARD_AUTH=basic
BULL_BOARD_PATH=/admin/queues
BULL_BOARD_TITLE=Export Queue Admin
BULL_BOARD_QUEUES=export-jobs
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=change-me

# Bull Board OIDC login
# Set BULL_BOARD_AUTH=oidc and configure the values below to enable OIDC.
# When OIDC is enabled, BULL_BOARD_USERNAME/BULL_BOARD_PASSWORD are ignored.
OIDC_ISSUER=https://id.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_SESSION_SECRET=replace-with-at-least-32-random-characters
OIDC_BASE_URL=http://localhost:8001
# OIDC_CALLBACK_URL can override OIDC_BASE_URL + OIDC_CALLBACK_PATH.
# OIDC_CALLBACK_URL=http://localhost:8001/admin/queues/callback
OIDC_LOGIN_PATH=/admin/queues/login
OIDC_CALLBACK_PATH=/admin/queues/callback
OIDC_LOGOUT_PATH=/admin/queues/logout
OIDC_SCOPES=openid,profile,email
OIDC_ALLOWED_EMAILS=
OIDC_ALLOWED_DOMAINS=
OIDC_SESSION_MAX_AGE_SECONDS=86400
OIDC_COOKIE_SECURE=auto
OIDC_COOKIE_SAME_SITE=lax

# Redis
REDIS_URL=redis://127.0.0.1:6379/0
